{
  "name": "@poolse/react-native",
  "version": "2.0.13",
  "description": "Plug-and-play React Native components for poolse — realtime chat infrastructure. Brand-aligned defaults, JS theme tokens, Expo-friendly out of the box.",
  "license": "MIT",
  "keywords": [
    "poolse",
    "chat",
    "react-native",
    "expo",
    "ui",
    "components",
    "messaging",
    "realtime"
  ],
  "homepage": "https://poolse.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poolse-hq/js-sdk.git",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/poolse-hq/js-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "dev": "tsup --watch src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@poolse/react": "workspace:*",
    "@poolse/sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "react-native-svg": ">=14",
    "expo-image-picker": "*",
    "expo-document-picker": "*",
    "expo-image-manipulator": "*"
  },
  "peerDependenciesMeta": {
    "expo-image-picker": {
      "optional": true
    },
    "expo-document-picker": {
      "optional": true
    },
    "expo-image-manipulator": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "expo-document-picker": "^12.0.0",
    "expo-haptics": "^14.0.0",
    "expo-image-manipulator": "^14.0.0",
    "expo-image-picker": "^16.0.0",
    "react": "^19.0.0",
    "react-native": "^0.76.0",
    "react-native-svg": "^15.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
