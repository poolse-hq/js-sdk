{
  "name": "@poolse/react-native",
  "version": "2.1.6",
  "description": "React Native chat SDK for Expo and bare RN. Drop-in ConversationView + PoolseInbox with camera, attachments, markdown, AppState lifecycle, KeyboardAvoidingView baked in. JS theme tokens. MIT — alternative to sendbird-chat-react-native and stream-chat-react-native.",
  "license": "MIT",
  "keywords": [
    "chat",
    "chat-sdk",
    "react-native",
    "react-native-chat",
    "react-native-messaging",
    "expo",
    "expo-chat",
    "expo-router",
    "mobile-chat",
    "in-app-chat",
    "in-app-messaging",
    "ios",
    "android",
    "realtime",
    "realtime-chat",
    "messaging",
    "typescript",
    "sendbird-react-native",
    "stream-chat-react-native",
    "poolse"
  ],
  "homepage": "https://poolse.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poolse-hq/js-sdk.git",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/poolse-hq/js-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "dev": "tsup --watch src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@poolse/react": "workspace:*",
    "@poolse/sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "react-native-svg": ">=14",
    "react-native-safe-area-context": ">=4",
    "expo-image-picker": "*",
    "expo-document-picker": "*",
    "expo-image-manipulator": "*",
    "expo-clipboard": "*",
    "react-native-markdown-display": ">=7"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "expo-document-picker": "^12.0.0",
    "expo-haptics": "^14.0.0",
    "expo-image-manipulator": "^14.0.0",
    "expo-image-picker": "^16.0.0",
    "react": "^19.0.0",
    "react-native": "^0.76.0",
    "react-native-svg": "^15.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
