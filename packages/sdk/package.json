{
  "name": "@poolse/sdk",
  "version": "0.0.2",
  "description": "Headless TypeScript SDK for the poolse Chat-as-a-Service API. REST + WebSocket + offline queue. Framework-agnostic — use directly, or via @poolse/react.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test"
  },
  "dependencies": {
    "phoenix": "^1.8.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/phoenix": "^1.6.7"
  }
}
