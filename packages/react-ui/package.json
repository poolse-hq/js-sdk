{
  "name": "@poolse/react-ui",
  "version": "2.1.6",
  "description": "React chat UI components — ConversationView, PoolseInbox, MessageBubble, TypingIndicator, ReactionPicker, ThreadView. CSS-variable theming, render-prop escape hatches. MIT — alternative to Sendbird, Stream, TalkJS, CometChat.",
  "license": "MIT",
  "keywords": [
    "chat",
    "chat-sdk",
    "chat-components",
    "chat-ui",
    "react",
    "react-chat",
    "react-components",
    "ui",
    "ui-components",
    "nextjs",
    "typescript",
    "messaging",
    "realtime",
    "realtime-chat",
    "conversation-view",
    "css-variables",
    "sendbird-alternative",
    "stream-chat-alternative",
    "talkjs-alternative",
    "poolse"
  ],
  "homepage": "https://poolse.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poolse-hq/js-sdk.git",
    "directory": "packages/react-ui"
  },
  "bugs": {
    "url": "https://github.com/poolse-hq/js-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@poolse/react": "workspace:*",
    "@poolse/sdk": "workspace:*",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "happy-dom": "^15.11.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
