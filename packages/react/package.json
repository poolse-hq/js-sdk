{
  "name": "@poolse/react",
  "version": "2.1.6",
  "description": "React hooks for realtime chat — PoolseProvider plus useMessages, useTyping, usePresence, useReactions, useMembers, useAttachmentUpload. Works on web and React Native. No UI. MIT — alternative to sendbird-chat-react and stream-chat-react.",
  "license": "MIT",
  "keywords": [
    "chat",
    "chat-sdk",
    "chat-hooks",
    "react-chat",
    "react",
    "react-hooks",
    "hooks",
    "realtime",
    "realtime-chat",
    "messaging",
    "websocket",
    "typescript",
    "in-app-messaging",
    "use-messages",
    "use-typing",
    "use-presence",
    "sendbird-alternative",
    "stream-chat-alternative",
    "poolse"
  ],
  "homepage": "https://poolse.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poolse-hq/js-sdk.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/poolse-hq/js-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@poolse/sdk": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "happy-dom": "^15.11.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
